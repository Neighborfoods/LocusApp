{
  "name": "AsyncStorage",
  "version": "3.0.1",
  "summary": "Asynchronous, persistent, key-value storage system for React Native.",
  "homepage": "https://github.com/react-native-async-storage/async-storage#readme",
  "license": "MIT",
  "authors": "Krzysztof Borowy <contact@kborowy.com> (https://www.kborowy.com)",
  "platforms": {
    "ios": "13.0",
    "osx": "12.0",
    "visionos": "1.0"
  },
  "source": {
    "git": "https://github.com/react-native-async-storage/async-storage.git",
    "tag": "3.0.1"
  },
  "resource_bundles": {
    "AsyncStorage_resources": "apple/PrivacyInfo.xcprivacy"
  },
  "source_files": "apple/**/*.{h,m,mm,cpp,swift}",
  "swift_versions": "5.9.2",
  "ios": {
    "vendored_frameworks": "apple-frameworks/SharedAsyncStorage.xcframework"
  },
  "osx": {
    "vendored_frameworks": "apple-frameworks/SharedAsyncStorage.xcframework"
  },
  "compiler_flags": "-DFOLLY_NO_CONFIG -DFOLLY_MOBILE=1 -DFOLLY_USE_LIBCPP=1 -DFOLLY_CFG_NO_COROUTINES=1 -Wno-comma -Wno-shorten-64-to-32",
  "dependencies": {
    "React-Core": [],
    "RCT-Folly": [
      "2022.05.16.00"
    ],
    "glog": []
  },
  "pod_target_xcconfig": {
    "HEADER_SEARCH_PATHS": "\"$(PODS_ROOT)/boost\" \"$(PODS_ROOT)/Headers/Private/Yoga\"",
    "CLANG_CXX_LANGUAGE_STANDARD": "c++20"
  },
  "swift_version": "5.9.2"
}
