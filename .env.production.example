# Production environment template. Copy to .env.production and fill in values.
# Usage: cp .env.production.example .env.production && $EDITOR .env.production

# Database (required)
DB_NAME=locus
DB_USER=locus
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Security (required)
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING_32_CHARS_MIN

# Payments (optional; leave empty if not using Stripe)
STRIPE_KEY=
STRIPE_WEBHOOK_SECRET=

# API / App (for reference; mobile uses https://api.yourdomain.com when !__DEV__)
# API_DOMAIN=api.yourdomain.com
